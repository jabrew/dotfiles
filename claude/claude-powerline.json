{
  "theme": "custom",
  "display": {
    "padding": 1,
    "style": "powerline",
    "charset": "unicode",
    "colorCompatibility": "auto",
    "autoWrap": true,
    "lines": [
      {
        "segments": {
          "directory": {
            "enabled": true,
            "style": "basename"
          },
          "git": {
            "enabled": true,
            "showSha": false,
            "showWorkingTree": true,
            "showOperation": true,
            "showTag": false,
            "showTimeSinceCommit": false,
            "showStashCount": false,
            "showUpstream": false,
            "showRepoName": false
          },
          "model": {
            "enabled": true
          },
          "context": {
            "enabled": true,
            "showPercentageOnly": true,
            "displayStyle": "filled"
          }
        }
      },
      {
        "segments": {
          "session": {
            "enabled": false,
            "type": "tokens",
            "costSource": "calculated"
          },
          "block": {
            "enabled": true,
            "type": "weighted",
            "burnType": "cost"
          },
          "today": {
            "enabled": false,
            "type": "cost"
          }
        }
      }
    ]
  },
  "colors": {
    "custom": {
      "directory":       { "bg": "#7e99d6", "fg": "#303446" },
      "git":             { "bg": "#95bc7b", "fg": "#303446" },
      "model":           { "bg": "#b68ecf", "fg": "#303446" },
      "context":         { "bg": "#8abcc5", "fg": "#303446" },
      "contextWarning":  { "bg": "#ceb482", "fg": "#303446" },
      "contextCritical": { "bg": "#d07577", "fg": "#303446" },
      "session":         { "bg": "#74b4ab", "fg": "#303446" },
      "block":           { "bg": "#d78f6a", "fg": "#303446" },
      "today":           { "bg": "#ceb482", "fg": "#303446" },
      "metrics":         { "bg": "#3b3e50", "fg": "#c6d0f5" },
      "version":         { "bg": "#3b3e50", "fg": "#c6d0f5" },
      "tmux":            { "bg": "#3b3e50", "fg": "#c6d0f5" }
    }
  },
  "budget": {
    "session": { "warningThreshold": 80 },
    "today":   { "amount": 10.0, "warningThreshold": 80 },
    "block":   { "warningThreshold": 80 }
  }
}
