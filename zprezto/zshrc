  source "${ZDOTDIR:-$HOME}/.zprezto/contrib/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
fi

# atuin - shell history (local mode, no sync)
eval "$(atuin init zsh --disable-up-arrow)"

